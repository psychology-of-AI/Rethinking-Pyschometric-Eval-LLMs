{
  "_doc": "psycohere_v1 \u2014 Honesty x Big5 between-session merge. Same per-question structure as TPB honesty merge. merge_selfreport_cct.py joins Big5 (1 row/condition) with per-question behavioral data producing long CSV. No alignment expressions \u2014 neutral framing only.",
  "task_name": "honesty",
  "framework": "big5",
  "study": "psycohere_v1",
  "join_keys": [
    "model_key",
    "temperature",
    "top_p",
    "seed",
    "persona_label"
  ],
  "big5": {
    "trait_cols": [
      "extraversion_mean",
      "agreeableness_mean",
      "conscientiousness_mean",
      "neuroticism_mean",
      "openness_mean"
    ]
  },
  "behavior": {
    "episode_cols": [
      "question_id"
    ],
    "carry_cols": [
      "brier_c1",
      "brier_c2",
      "confidence_delta",
      "inconsistency_abs",
      "brier_improvement",
      "is_correct_em",
      "calib_error_abs"
    ],
    "precompute_cols": [
      {
        "name": "brier_c1_safe",
        "expr": "pd.to_numeric(brier_c1, errors='coerce').clip(0, 1)"
      },
      {
        "name": "inconsistency_abs_safe",
        "expr": "pd.to_numeric(inconsistency_abs, errors='coerce').clip(0, 1)"
      }
    ]
  }
}